# ─── Supabase ────────────────────────────────────────────────────────────────
# URL pública do projeto Supabase (ex: https://xxxx.supabase.co)
SUPABASE_URL=
VITE_SUPABASE_URL=

# Chave anon/public (safe para frontend)
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Project ID (usado no client.ts)
VITE_SUPABASE_PROJECT_ID=

# ─── Deploy ───────────────────────────────────────────────────────────────────
# Porta exposta no host da VPS (deve ser uma porta livre)
# Padrão: 3100  — mude se já estiver em uso
HOST_PORT=3100
